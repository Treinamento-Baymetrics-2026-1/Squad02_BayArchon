[sqlfluff]
# Define qual o banco de dados alvo
dialect = postgres

# Ignora a pasta target ou dependências
exclude_rules = LT01, LT02, LT12
ignore = templating

# Define o tamanho máximo da linha
max_line_length = 300




[sqlfluff:indentation]
# Configura o estilo de indentação
tab_space_size = 1
indent_unit = tab



[sqlfluff:rules:capitalisation.keywords]
# Força palavras reservadas a serem MAIÚSCULAS
capitalisation_policy = upper



[sqlfluff:rules:capitalisation.identifiers]
# Força nomes de tabelas/colunas a serem minúsculas
capitalisation_policy = lower



[sqlfluff:rules:aliasing.table]
# Exige que você sempre use a palavra 'AS' 
# ao dar apelido a uma tabela
aliasing = explicit



[sqlfluff:rules:ambiguous.column_references]
# Em queries com JOIN, exige que as colunas informem de qual tabela vieram (ex: t1.nome)
group_by_and_order_by_style = explicit
